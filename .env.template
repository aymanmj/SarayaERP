# ============================================
# Saraya ERP - Production Environment Variables
# ============================================
# انسخ هذا الملف إلى .env.production وأكمل القيم
# cp .env.template .env.production
# ln -sf .env.production .env

# ==========================================
# 🗄️ قاعدة البيانات (Database)
# ==========================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=          # كلمة مرور قوية (مثل: openssl rand -base64 32)
POSTGRES_DB=saraya_erp
# يُبنى تلقائياً من القيم أعلاه — لا تغيّره يدوياً إلا إذا كنت تعرف ما تفعل
# DATABASE_URL=postgresql://admin:PASSWORD@postgres:5432/saraya_erp?schema=public

# ==========================================
# 🔐 المصادقة (Authentication)
# ==========================================
JWT_SECRET=                 # مفتاح JWT قوي (مثل: openssl rand -hex 32)
JWT_EXPIRES_IN=86400s       # مدة صلاحية التوكن (24 ساعة)

# ==========================================
# 🔒 التشفير (Patient Data Encryption - AES-256)
# ==========================================
# مفتاح AES-256 لتشفير بيانات المرضى الحساسة
# أنشئه باستخدام: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ⚠️ تحذير: لا تُغيّر هذا المفتاح أبداً بعد بدء تخزين البيانات!
ENCRYPTION_KEY=
ENCRYPTION_SALT=saraya-default-salt-123

# ==========================================
# 🌐 CORS (مصادر الوصول المسموحة)
# ==========================================
# قائمة المصادر المسموحة (مفصولة بفواصل)
# مثال: https://saraya.example.com,https://admin.example.com
CORS_ORIGINS=

# ==========================================
# 💾 Redis
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=             # كلمة مرور Redis (مثل: openssl rand -base64 16)

# ==========================================
# 📧 البريد الإلكتروني (SMTP)
# ==========================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@sarayaerp.com

# ==========================================
# 📱 تيليجرام — بوابة المريض (Patient Portal OTP)
# ==========================================
# احصل على التوكن من: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_URL=https://t.me/SarayaMedBot

# ==========================================
# 🔑 HashiCorp Vault (إدارة الأسرار)
# ==========================================
# يتم توليد التوكن تلقائياً عند أول تشغيل
# VAULT_ADDR=http://vault:8200
# VAULT_TOKEN=               # يُستخرج تلقائياً من vault-auto-unseal

# ==========================================
# 🔑 SSL Certificates
# ==========================================
# مسار مجلد الشهادات (يجب أن يحتوي على fullchain.pem و privkey.pem)
SSL_CERT_PATH=./certs

# ==========================================
# 📜 الترخيص (License)
# ==========================================
LICENSE_PATH=/app/data/license/saraya.lic

# ==========================================
# ☁️ Cloudflare Tunnel (الوصول من الإنترنت بدون فتح منافذ)
# ==========================================
# كل عميل يحتاج Tunnel Token خاص به
# أنشئه من: https://one.dash.cloudflare.com → Zero Trust → Tunnels
TUNNEL_TOKEN=

# ==========================================
# 🌐 Tailscale VPN (الصيانة عن بعد)
# ==========================================
# احصل على المفتاح من: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTHKEY=
TAILSCALE_HOSTNAME=saraya-erp

# ==========================================
# 💾 النسخ الاحتياطي (Backup)
# ==========================================
BACKUP_PATH=./backups
BACKUP_SCHEDULE="0 2,14 * * *"
BACKUP_RETENTION_DAYS=30

# ==========================================
# 📊 المراقبة (Monitoring)
# ==========================================
GRAFANA_PASSWORD=           # كلمة مرور Grafana (غيّرها من القيمة الافتراضية!)

# ==========================================
# 🐳 Docker / GHCR
# ==========================================
IMAGE_TAG=latest
GITHUB_REPOSITORY_OWNER=aymanmj

# ==========================================
# 🔄 التحديث التلقائي (Watchtower)
# ==========================================
WATCHTOWER_TOKEN=           # توكن أمان (مثل: openssl rand -base64 24)
