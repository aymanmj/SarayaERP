# ============================================
# Saraya ERP - Environment Configuration
# ============================================
# انسخ هذا الملف إلى .env وقم بتعبئة القيم المناسبة
# Copy this file to .env and fill in appropriate values

# ============================================
# Database Configuration (قاعدة البيانات)
# ============================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=saraya_erp
# DATABASE_URL is auto-constructed by docker-compose from above values
# DATABASE_URL=postgresql://admin:your_secure_password_here@postgres:5432/saraya_erp?schema=public

# ============================================
# Security (الأمان)
# ============================================
# مفتاح JWT - يجب أن يكون طويل وعشوائي (32 حرف على الأقل)
JWT_SECRET=your_very_long_random_secret_key_here_at_least_32_chars
JWT_EXPIRES_IN=86400s

# كلمة مرور Redis
REDIS_PASSWORD=your_redis_password_here

# ============================================
# Encryption (تشفير بيانات المرضى - AES-256)
# ============================================
# أنشئه: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ⚠️ لا تُغيّره أبداً بعد بدء تخزين البيانات!
ENCRYPTION_KEY=your_base64_encryption_key_here
ENCRYPTION_SALT=saraya-default-salt-123

# ============================================
# CORS (مصادر الوصول المسموحة)
# ============================================
# مفصولة بفواصل: https://saraya.example.com,https://admin.example.com
CORS_ORIGINS=

# ============================================
# Server Configuration (إعدادات السيرفر)
# ============================================
SERVER_PORT=3000
NODE_ENV=production

# ============================================
# Email Configuration (البريد الإلكتروني)
# ============================================
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@sarayaerp.com

# ============================================
# Telegram Bot (بوابة المريض - OTP)
# ============================================
# احصل على التوكن من: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_URL=https://t.me/SarayaMedBot
# عنوان الـ Webhook — يتم حسابه تلقائياً من الدومين أثناء التثبيت
# مثال: https://rehab.alsarayatech.ly/api
TELEGRAM_WEBHOOK_URL=

# ============================================
# AI Services (الذكاء الاصطناعي)
# ============================================
# مفتاح Google Gemini (للمساعد البرمجي)
GEMINI_API_KEY=your_gemini_api_key

# ============================================
# License (الترخيص)
# ============================================
LICENSE_PATH=/app/data/license/saraya.lic

# ============================================
# File Upload (رفع الملفات)
# ============================================
MAX_FILE_SIZE=10485760

# ============================================
# Paths (المسارات)
# ============================================
BACKUP_PATH=./backups
BACKUP_SCHEDULE="0 2,14 * * *"
BACKUP_RETENTION_DAYS=30
SSL_PATH=./certs

# ============================================
# Monitoring (المراقبة)
# ============================================
GRAFANA_PASSWORD=change_this_password

# ============================================
# Cloudflare Tunnel (الوصول من الإنترنت)
# ============================================
# أنشئه من: https://one.dash.cloudflare.com → Zero Trust → Tunnels
TUNNEL_TOKEN=

# ============================================
# Remote Access - Tailscale (الصيانة عن بعد)
# ============================================
# مفتاح Tailscale - احصل عليه من: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTHKEY=tskey-auth-xxxxx
TAILSCALE_HOSTNAME=saraya-erp

# ============================================
# GitHub Container Registry (للتحديث التلقائي)
# ============================================
GITHUB_REPOSITORY_OWNER=your_github_username
IMAGE_TAG=latest

# ============================================
# Watchtower (التحديث التلقائي)
# ============================================
# Token للوصول لـ Watchtower API - غيّره لقيمة آمنة
WATCHTOWER_TOKEN=change-this-to-secure-token
